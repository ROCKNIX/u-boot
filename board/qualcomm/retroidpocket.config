# Configuration for building Retroid Pocket SM8250 U-Boot
CONFIG_DEFAULT_DEVICE_TREE="qcom/sm8250-retroidpocket-rp5"
CONFIG_DEFAULT_FDT_FILE="qcom/sm8250-retroidpocket-rp5.dtb"
# CONFIG_OF_UPSTREAM_BUILD_VENDOR is not set
CONFIG_DEFAULT_ENV_FILE="board/qualcomm/retroidpocket.env"
CONFIG_USE_DEFAULT_ENV_FILE=y
CONFIG_PANIC_HANG=y
CONFIG_CMD_PAUSE=y
CONFIG_BOOTSTD=y
CONFIG_BOOTSTD_IGNORE_BOOTABLE=y
CONFIG_BOOT_RETRY=y
CONFIG_BOOT_RETRY_TIME=1
CONFIG_CONSOLE_ROTATION=y
