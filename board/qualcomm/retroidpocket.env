bootdelay=0
stdin=serial,button-kbd
stdout=serial,vidconsole
stderr=serial,vidconsole
bootmenu_0=Boot Linux=bootefi bootmgr; pause
bootmenu_1=Reboot=reset
bootmenu_2=Power Off=poweroff
bootmenu_3=Dump environment=printenv; pause
button_cmd_0_name=pwrkey
button_cmd_0=run menucmd
# Override bootcmd to return to the menu so boot retry will
# just open the menu again.
menucmd=setenv bootcmd run menucmd; bootmenu -1
bootcmd=bootefi bootmgr; pause
